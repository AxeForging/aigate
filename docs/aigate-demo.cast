{"version": 2, "width": 130, "height": 30, "timestamp": 1775685449, "idle_time_limit": 3.0, "env": {"SHELL": "/usr/bin/zsh", "TERM": "tmux-256color"}, "title": "aigate вҖ” sandbox AI agents in seconds"}
[0.011109, "o", "\u001b[H\u001b[J\u001b[3J"]
[0.515434, "o", "\u001b[2;36m# aigate вҖ” wrap any command in an OS-level sandbox for AI agents\u001b[0m\r\n"]
[2.316579, "o", "\u001b[2;36m# every example below uses the default rules from ~/.aigate/config.yaml\u001b[0m\r\n"]
[4.318677, "o", "\u001b[H\u001b[J\u001b[3J"]
[4.719883, "o", "\u001b[2;36m# 1) deny_exec вҖ” shell tools blocked even when installed on the host\u001b[0m\r\n"]
